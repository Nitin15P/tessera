{
  "name": "tessera",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Real-time shared grid — claim tiles, steal them, see everyone live.",
  "workspaces": [
    "shared",
    "backend",
    "frontend"
  ],
  "scripts": {
    "dev": "concurrently -n backend,frontend -c cyan,magenta \"npm:dev:backend\" \"npm:dev:frontend\"",
    "dev:backend": "npm run dev --workspace=@tessera/backend",
    "dev:frontend": "npm run dev --workspace=@tessera/frontend",
    "build": "npm run build --workspace=@tessera/frontend && npm run build --workspace=@tessera/backend",
    "start": "npm run start --workspace=@tessera/backend",
    "typecheck": "tsc -p shared && tsc -p backend && tsc -p frontend",
    "test:race": "npm run test:race --workspace=@tessera/backend",
    "test:bucket": "npm run test:bucket --workspace=@tessera/backend",
    "test:steal": "npm run test:steal --workspace=@tessera/backend",
    "test:stress": "npm run test:stress --workspace=@tessera/backend",
    "test:edge": "npm run test:edge --workspace=@tessera/backend",
    "test:cross": "npm run test:cross --workspace=@tessera/backend",
    "verify": "npm run test:race && npm run test:bucket && npm run test:steal && npm run test:edge && npm run test:cross"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "typescript": "^5.7.3"
  },
  "engines": {
    "node": ">=20"
  }
}
